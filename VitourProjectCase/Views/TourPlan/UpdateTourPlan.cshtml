@model GetTourPlanByIdDto

@{
    var tourName = ViewBag.TourName as string ?? "Tur";
    var tourId = ViewBag.TourId as string ?? "";
    var dayCount = ViewBag.TourDayCount as int? ?? 0;

    ViewData["Title"] = "Plan Düzenle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActiveMenu"] = "turlar";
    ViewData["Breadcrumb"] = "Turlar / " + tourName + " / Planlar / Düzenle";

    var dayColors = new[] {
        "#0284c7","#16a34a","#a855f7","#f59e0b","#ef4444",
        "#0891b2","#7c3aed","#059669","#dc2626","#d97706"
    };

    string DayColor(int d) => d > 0 ? dayColors[(d - 1) % dayColors.Length] : "#cbd5e1";
    var currentColor = DayColor(Model?.DayNumber ?? 0);
}

<style>
    .edit-grid {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 24px;
        align-items: start;
    }

    .v-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
    }

    .v-card-header {
        padding: 18px 24px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .v-card-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
    }

    .v-card-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--t1);
    }

    .v-card-sub {
        font-size: 11.5px;
        color: var(--t3);
        margin-top: 2px;
    }

    .form-body {
        padding: 22px 24px;
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--t2);
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .form-label .req {
            color: #ef4444;
            font-size: 15px;
            line-height: 1;
        }

    .form-hint {
        font-size: 11.5px;
        color: var(--t3);
    }

    .form-control {
        width: 100%;
        height: 42px;
        padding: 0 14px;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        background: var(--bg-canvas);
        color: var(--t1);
        font-family: inherit;
        font-size: 14px;
        transition: border-color .18s,box-shadow .18s;
        outline: none;
        appearance: none;
    }

        .form-control:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-glow);
            background: #fff;
        }

        .form-control::placeholder {
            color: var(--t3);
        }

        .form-control.input-validation-error {
            border-color: #ef4444;
            box-shadow: 0 0 0 3px rgba(239,68,68,.10);
        }

    textarea.form-control {
        height: auto;
        padding: 12px 14px;
        resize: vertical;
        min-height: 140px;
        line-height: 1.65;
    }

    .field-validation-error:empty {
        display: none !important;
    }

    .field-validation-error:not(:empty) {
        font-size: 12px;
        color: #ef4444;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .field-validation-error:not(:empty)::before {
            content: '\f071';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            font-size: 10px;
            flex-shrink: 0;
        }

    .alert-danger {
        padding: 12px 16px;
        background: rgba(239,68,68,.06);
        border: 1px solid rgba(239,68,68,.2);
        border-radius: var(--radius-sm);
        font-size: 13px;
        color: #b91c1c;
        align-items: flex-start;
        gap: 10px;
    }

        .alert-danger i {
            flex-shrink: 0;
            margin-top: 1px;
        }

        .alert-danger ul {
            margin: 4px 0 0 14px;
        }

        .alert-danger li {
            margin-bottom: 2px;
        }

    /* ── ID alanı ─────────────────────────────────────────────── */
    .id-field {
        display: flex;
        align-items: center;
        gap: 9px;
        height: 42px;
        padding: 0 14px;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        background: #f8fafc;
        font-size: 12.5px;
        color: var(--t3);
        font-family: monospace;
    }

    /* ── Gün numarası seçici ──────────────────────────────────── */
    .day-picker {
        display: flex;
        align-items: center;
        gap: 0;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        overflow: hidden;
        background: var(--bg-canvas);
        transition: border-color .18s,box-shadow .18s;
        width: fit-content;
    }

        .day-picker:focus-within {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-glow);
            background: #fff;
        }

    .day-btn {
        width: 40px;
        height: 42px;
        border: none;
        background: #f1f5f9;
        color: var(--t2);
        font-size: 16px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background .16s,color .16s;
        flex-shrink: 0;
        user-select: none;
    }

        .day-btn:hover {
            background: var(--bg-hover);
            color: var(--accent);
        }

        .day-btn:first-child {
            border-right: 1.5px solid var(--border);
        }

        .day-btn:last-child {
            border-left: 1.5px solid var(--border);
        }

    #dayInput {
        width: 70px;
        text-align: center;
        border: none;
        background: transparent;
        font-size: 20px;
        font-weight: 800;
        color: var(--t1);
        outline: none;
        height: 42px;
        -moz-appearance: textfield;
    }

        #dayInput::-webkit-outer-spin-button,
        #dayInput::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

    .day-color-strip {
        width: 100%;
        height: 4px;
        border-radius: 99px;
        margin-top: 6px;
        transition: background .3s;
    }

    /* ── Değişiklik uyarısı ───────────────────────────────────── */
    .change-alert {
        display: none;
        align-items: center;
        gap: 9px;
        padding: 10px 14px;
        background: rgba(245,158,11,.07);
        border: 1px solid rgba(245,158,11,.25);
        border-radius: var(--radius-sm);
        font-size: 12.5px;
        color: #92400e;
    }

        .change-alert.visible {
            display: flex;
        }

        .change-alert i {
            color: #f59e0b;
            font-size: 13px;
            flex-shrink: 0;
        }

    /* ── Footer ───────────────────────────────────────────────── */
    .form-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
    }

    /* ── Butonlar ─────────────────────────────────────────────── */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 0 18px;
        height: 40px;
        border-radius: var(--radius-sm);
        font-family: inherit;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        text-decoration: none;
        transition: all .18s;
        white-space: nowrap;
    }

    .btn-primary {
        background: var(--accent);
        color: #fff;
        box-shadow: 0 2px 8px var(--accent-glow);
    }

        .btn-primary:hover {
            background: #0369a1;
            box-shadow: 0 4px 16px rgba(2,132,199,.28);
            transform: translateY(-1px);
        }

    .btn-ghost {
        background: transparent;
        border: 1.5px solid var(--border);
        color: var(--t2);
    }

        .btn-ghost:hover {
            background: var(--bg-hover);
            color: var(--t1);
        }

    .btn-danger-soft {
        background: rgba(239,68,68,.07);
        border: 1.5px solid rgba(239,68,68,.2);
        color: #dc2626;
    }

        .btn-danger-soft:hover {
            background: rgba(239,68,68,.14);
            border-color: rgba(239,68,68,.35);
        }

    /* ── Sağ panel ────────────────────────────────────────────── */
    .side-panel {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* ── Plan önizleme kartı ──────────────────────────────────── */
    .plan-preview-card {
        margin: 16px;
        border-radius: var(--radius-sm);
        overflow: hidden;
        border: 1px solid var(--border);
        background: #fff;
    }

    .ppc-accent {
        height: 4px;
        transition: background .3s;
    }

    .ppc-header {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 16px;
        border-bottom: 1px solid var(--border);
    }

    .ppc-day-badge {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: background .3s;
    }

    .ppc-day-num {
        font-size: 18px;
        font-weight: 900;
        line-height: 1;
        color: #fff;
    }

    .ppc-day-label {
        font-size: 9px;
        font-weight: 700;
        color: rgba(255,255,255,.75);
        letter-spacing: .5px;
        text-transform: uppercase;
    }

    .ppc-title-wrap {
        flex: 1;
        min-width: 0;
    }

    .ppc-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--t1);
        min-height: 18px;
    }

    .ppc-tour {
        font-size: 11.5px;
        color: var(--t3);
        margin-top: 3px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .ppc-body {
        padding: 14px 16px;
    }

    .ppc-desc {
        font-size: 13px;
        color: var(--t2);
        line-height: 1.65;
        white-space: pre-wrap;
        min-height: 18px;
    }

    .ppc-footer {
        padding: 9px 16px;
        border-top: 1px solid var(--border);
        background: #f8fafc;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 11.5px;
        color: var(--t3);
    }

    /* ── Meta bilgiler ────────────────────────────────────────── */
    .meta-list {
        padding: 16px 20px;
        display: flex;
        flex-direction: column;
        gap: 11px;
    }

    .meta-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 13px;
    }

    .meta-key {
        color: var(--t3);
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .meta-key i {
            width: 14px;
            text-align: center;
            font-size: 12px;
        }

    .meta-val {
        font-weight: 600;
        color: var(--t1);
        font-size: 12.5px;
    }

    .meta-sep {
        height: 1px;
        background: var(--border);
    }

    /* ── Diğer planlar ────────────────────────────────────────── */
    .other-plan {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 12px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        background: var(--bg-canvas);
        margin-bottom: 8px;
        transition: border-color .16s;
    }

        .other-plan:last-child {
            margin-bottom: 0;
        }

        .other-plan:hover {
            border-color: #93c5fd;
        }

        .other-plan.current {
            border-color: var(--accent);
            background: #f0f8ff;
        }

    .op-day {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 800;
        color: #fff;
        flex-shrink: 0;
    }

    .op-title {
        font-size: 12.5px;
        font-weight: 600;
        color: var(--t1);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        flex: 1;
        min-width: 0;
    }

    .op-current {
        font-size: 10px;
        font-weight: 700;
        color: var(--accent);
        flex-shrink: 0;
    }

    /* ── Tehlikeli alan ───────────────────────────────────────── */
    .danger-zone {
        padding: 16px 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

        .danger-zone p {
            font-size: 12.5px;
            color: var(--t3);
            line-height: 1.5;
        }

    @@media (max-width:960px) {
        .edit-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<!-- ── Sayfa Başlığı ─────────────────────────────────────────── -->
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:26px;flex-wrap:wrap;gap:12px;">
    <div style="display:flex;align-items:center;gap:14px;">
        <a href="/admin/turlar/@tourId/plan" class="btn btn-ghost" style="height:38px;padding:0 14px;">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div>
            <h1 style="font-size:20px;font-weight:700;color:var(--t1);">Plan Düzenle</h1>
            <p style="font-size:13px;color:var(--t3);margin-top:3px;">
                <strong style="color:var(--t2);">@tourName</strong> —
                <span style="color:@currentColor;font-weight:600;" id="pageSubtitle">
                    @Model?.DayNumber. Gün: @Model?.Title
                </span>
            </p>
        </div>
    </div>
    <a href="/admin/turlar/@tourId/plan" class="btn btn-ghost">
        <i class="fa-solid fa-list"></i> Tüm Planlar
    </a>
</div>

<div class="edit-grid">

    <!-- ══ SOL — Form ══════════════════════════════════════════ -->
    <div style="display:flex;flex-direction:column;gap:20px;">

        <div class="change-alert" id="changeAlert">
            <i class="fa-solid fa-triangle-exclamation"></i>
            Kaydedilmemiş değişiklikleriniz var. Kaydetmeyi unutmayın.
        </div>

        <div asp-validation-summary="ModelOnly" class="alert-danger" style="display:none;">
            <i class="fa-solid fa-circle-exclamation"></i>
            <div><strong>Hataları düzeltin:</strong><ul></ul></div>
        </div>

        <form method="post" novalidate id="editPlanForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="TourPlanId" />
            <input type="hidden" asp-for="TourId"/>

            <div style="display:flex;flex-direction:column;gap:20px;">

                <!-- 1. Plan Bilgileri -->
                <div class="v-card">
                    <div class="v-card-header">
                        <div class="v-card-icon" style="background:rgba(2,132,199,.1);color:var(--accent);">
                            <i class="fa-solid fa-calendar-day"></i>
                        </div>
                        <div>
                            <div class="v-card-title">Plan Bilgileri</div>
                            <div class="v-card-sub">Gün numarası ve başlık</div>
                        </div>
                    </div>

                    <div class="form-body">

                        <!-- Plan ID readonly -->
                        <div class="form-group">
                            <label class="form-label">
                                <i class="fa-solid fa-fingerprint" style="color:var(--accent);font-size:12px;"></i>
                                Plan ID
                            </label>
                            <div class="id-field">
                                <i class="fa-solid fa-lock"></i>&nbsp;@Model?.TourPlanId
                            </div>
                            <span class="form-hint">Otomatik atanmıştır, değiştirilemez.</span>
                        </div>

                        <!-- Gün numarası -->
                        <div class="form-group">
                            <label class="form-label">
                                <i class="fa-solid fa-hashtag" style="color:var(--accent);font-size:12px;"></i>
                                Gün Numarası <span class="req">*</span>
                            </label>

                            <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
                                <div class="day-picker">
                                    <button type="button" class="day-btn" onclick="changeDay(-1)">
                                        <i class="fa-solid fa-minus" style="font-size:12px;"></i>
                                    </button>
                                    <input asp-for="DayNumber" id="dayInput" type="number"
                                           min="1" max="365" oninput="onDayInput()" />
                                    <button type="button" class="day-btn" onclick="changeDay(1)">
                                        <i class="fa-solid fa-plus" style="font-size:12px;"></i>
                                    </button>
                                </div>
                                <div id="dayLabel" style="font-size:13.5px;font-weight:600;color:@currentColor;">
                                    @(Model?.DayNumber > 0 ? Model.DayNumber + ". Gün" : "— gün seçin —")
                                </div>
                            </div>

                            <div class="day-color-strip" id="dayColorStrip"
                                 style="background:@currentColor;"></div>
                            <span asp-validation-for="DayNumber" class="field-validation-error"></span>

                            @if (dayCount > 0)
                            {
                                <span class="form-hint">
                                    Bu tur <strong>@dayCount günlük</strong> —
                                    1 ile @dayCount arasında bir gün girin.
                                </span>
                            }
                        </div>

                        <!-- Başlık -->
                        <div class="form-group">
                            <label asp-for="Title" class="form-label">
                                <i class="fa-solid fa-heading" style="color:var(--accent);font-size:12px;"></i>
                                Plan Başlığı <span class="req">*</span>
                            </label>
                            <input asp-for="Title" class="form-control" id="planTitle"
                                   placeholder="Örn: Kapadokya'ya Varış & Şehir Turu"
                                   maxlength="120" autocomplete="off" />
                            <span asp-validation-for="Title" class="field-validation-error"></span>
                        </div>

                    </div>
                </div>

                <!-- 2. Gün Programı -->
                <div class="v-card">
                    <div class="v-card-header">
                        <div class="v-card-icon" style="background:rgba(168,85,247,.1);color:#a855f7;">
                            <i class="fa-solid fa-align-left"></i>
                        </div>
                        <div>
                            <div class="v-card-title">Gün Programı</div>
                            <div class="v-card-sub">Aktiviteler, saatler ve özel notlar</div>
                        </div>
                    </div>

                    <div class="form-body">
                        <div class="form-group">
                            <label asp-for="Description" class="form-label">
                                <i class="fa-solid fa-list-ul" style="color:#a855f7;font-size:12px;"></i>
                                Açıklama <span class="req">*</span>
                            </label>
                            <textarea asp-for="Description" class="form-control" id="planDesc"
                                      rows="8"></textarea>
                            <span asp-validation-for="Description" class="field-validation-error"></span>
                            <div style="display:flex;justify-content:space-between;align-items:center;margin-top:2px;">
                                <span class="form-hint">Her satıra bir aktivite veya saat dilimi ekleyin.</span>
                                <span style="font-size:11.5px;color:var(--t3);">
                                    <span id="descCount">@(Model?.Description?.Length ?? 0)</span> karakter
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="form-footer">
                        <a href="/admin/turlar/@tourId/plan" class="btn btn-ghost">
                            <i class="fa-solid fa-xmark"></i> İptal
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-floppy-disk"></i> Değişiklikleri Kaydet
                        </button>
                    </div>
                </div>

            </div>
        </form>
    </div>

    <!-- ══ SAĞ — Bilgi Paneli ═══════════════════════════════════ -->
    <div class="side-panel">

        <!-- Canlı Önizleme -->
        <div class="v-card">
            <div class="v-card-header">
                <div class="v-card-icon" style="background:rgba(168,85,247,.1);color:#a855f7;">
                    <i class="fa-solid fa-eye"></i>
                </div>
                <div>
                    <div class="v-card-title">Canlı Önizleme</div>
                    <div class="v-card-sub">Değişiklikler anlık yansır</div>
                </div>
            </div>

            <div class="plan-preview-card">
                <div class="ppc-accent" id="prevAccent" style="background:@currentColor;"></div>
                <div class="ppc-header">
                    <div class="ppc-day-badge" id="prevDayBadge" style="background:@currentColor;">
                        <div class="ppc-day-num" id="prevDayNum">@(Model?.DayNumber > 0 ? Model.DayNumber.ToString() : "—")</div>
                        <div class="ppc-day-label">GÜN</div>
                    </div>
                    <div class="ppc-title-wrap">
                        <div class="ppc-title" id="prevTitle">
                            @if (!string.IsNullOrEmpty(Model?.Title))
                            {
                                @Model.Title
                            }
                            else
                            {
                                <span style="color:var(--t3);font-weight:400;font-size:12px;">Başlık girilmedi…</span>
                            }
                        </div>
                        <div class="ppc-tour">
                            <i class="fa-solid fa-map-location-dot" style="font-size:10px;"></i>
                            @tourName
                        </div>
                    </div>
                </div>

                <div class="ppc-body">
                    <div class="ppc-desc" id="prevDesc">
                        @if (!string.IsNullOrEmpty(Model?.Description))
                        {
                            @Model.Description
                        }
                        else
                        {
                            <span style="color:var(--t3);font-style:italic;font-size:12px;">Açıklama girilmedi…</span>
                        }
                    </div>
                </div>

                <div class="ppc-footer">
                    <i class="fa-regular fa-clock" id="prevFooterIcon" style="color:@currentColor;"></i>
                    <span id="prevLineCount">
                        @{
                            var initLines = Model?.Description?.Split('\n').Count(l => l.Trim().Length > 0) ?? 0;
                        }
                        @initLines aktivite satırı
                    </span>
                </div>
            </div>
        </div>

        <!-- Kayıt Bilgileri -->
        <div class="v-card">
            <div class="v-card-header">
                <div class="v-card-icon" style="background:rgba(34,197,94,.1);color:#16a34a;">
                    <i class="fa-solid fa-circle-info"></i>
                </div>
                <div>
                    <div class="v-card-title">Kayıt Bilgileri</div>
                    <div class="v-card-sub">Bu plana ait meta veriler</div>
                </div>
            </div>
            <div class="meta-list">
                <div class="meta-row">
                    <span class="meta-key"><i class="fa-solid fa-id-badge"></i> Plan ID</span>
                    <span class="meta-val" style="font-family:monospace;font-size:10.5px;color:var(--t3);">@Model?.TourPlanId</span>
                </div>
                <div class="meta-sep"></div>
                <div class="meta-row">
                    <span class="meta-key"><i class="fa-solid fa-map-location-dot"></i> Tur ID</span>
                    <span class="meta-val" style="font-family:monospace;font-size:10.5px;color:var(--t3);">@Model?.TourId</span>
                </div>
                <div class="meta-sep"></div>
                <div class="meta-row">
                    <span class="meta-key"><i class="fa-regular fa-calendar-days"></i> Gün</span>
                    <span class="meta-val" id="metaDayVal">
                        <span style="background:@currentColor;color:#fff;padding:2px 10px;border-radius:20px;font-size:11.5px;" id="metaDayBadge">
                            @(Model?.DayNumber > 0 ? Model.DayNumber + ". Gün" : "—")
                        </span>
                    </span>
                </div>
                <div class="meta-sep"></div>
                <div class="meta-row">
                    <span class="meta-key"><i class="fa-regular fa-file-lines"></i> Satır Sayısı</span>
                    <span class="meta-val" id="metaLineCount">@initLines satır</span>
                </div>
                <div class="meta-sep"></div>
                <div class="meta-row">
                    <span class="meta-key"><i class="fa-solid fa-text-width"></i> Karakter</span>
                    <span class="meta-val" id="metaCharCount">@(Model?.Description?.Length ?? 0)</span>
                </div>
            </div>
        </div>

        <!-- Diğer Planlar -->
        @if (ViewBag.OtherPlans != null)
        {
            var others = ViewBag.OtherPlans as List<ResultTourPlanByTourIdDto>;
            if (others != null && others.Any())
            {
                <div class="v-card">
                    <div class="v-card-header">
                        <div class="v-card-icon" style="background:rgba(2,132,199,.1);color:var(--accent);">
                            <i class="fa-solid fa-list"></i>
                        </div>
                        <div>
                            <div class="v-card-title">Diğer Planlar</div>
                            <div class="v-card-sub">@tourName turunun planları</div>
                        </div>
                    </div>
                    <div style="padding:14px 16px;">
                        @{
                            var dayColors2 = new[] { "#0284c7", "#16a34a", "#a855f7", "#f59e0b", "#ef4444", "#0891b2", "#7c3aed", "#059669", "#dc2626", "#d97706" };
                        }
                        @foreach (var p in others.OrderBy(x => x.DayNumber))
                        {
                            var isCurrent = p.TourPlanId == Model?.TourPlanId;
                            var col2 = dayColors2[(p.DayNumber - 1) % dayColors2.Length];
                            <div class="other-plan @(isCurrent ? "current" : "")">
                                <div class="op-day" style="background:@col2;">@p.DayNumber</div>
                                <div class="op-title" title="@p.Title">@p.Title</div>
                                @if (isCurrent)
                                {
                                    <span class="op-current">← Şu an</span>
                                }
                                else
                                {
                                    <a href="/admin/turlar/@tourId/plan/duzenle/@p.TourPlanId"
                                       style="font-size:11px;color:var(--t3);text-decoration:none;flex-shrink:0;"
                                       title="Düzenle">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        }

        <!-- Tehlikeli Alan -->
        <div class="v-card" style="border-color:rgba(239,68,68,.18);">
            <div class="v-card-header" style="border-color:rgba(239,68,68,.1);">
                <div class="v-card-icon" style="background:rgba(239,68,68,.08);color:#dc2626;">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <div>
                    <div class="v-card-title" style="color:#dc2626;">Tehlikeli Alan</div>
                    <div class="v-card-sub">Bu işlem geri alınamaz</div>
                </div>
            </div>
            <div class="danger-zone">
                <p>Bu günlük planı sildiğinizde <strong>kalıcı olarak kaldırılır.</strong> Tur planı bütünlüğü bozulabilir.</p>
                <form asp-action="DeletePlan" asp-controller="TourPlan"
                      asp-route-id="@Model?.TourPlanId" method="post" id="deleteForm">
                    @Html.AntiForgeryToken()
                    <button type="button" onclick="confirmDelete()"
                            class="btn btn-danger-soft" style="width:100%;justify-content:center;">
                        <i class="fa-solid fa-trash"></i> Planı Kalıcı Sil
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function () {
            var s = document.querySelector('[data-valmsg-summary]');
            if (s && s.querySelectorAll('li').length > 0) s.style.display = 'flex';
        })();

        /* ── Orijinal değerler ── */
        var orig = {
            day   : document.getElementById('dayInput').value,
            title : document.getElementById('planTitle').value,
            desc  : document.getElementById('planDesc').value
        };

        /* ── Renk paleti ── */
        var dayColors = [
            '#0284c7','#16a34a','#a855f7','#f59e0b','#ef4444',
            '#0891b2','#7c3aed','#059669','#dc2626','#d97706'
        ];

        function getDayColor(day) {
            if (!day || day < 1) return '#cbd5e1';
            return dayColors[(day - 1) % dayColors.length];
        }

        var dayLabels = {
            1:'Birinci Gün', 2:'İkinci Gün', 3:'Üçüncü Gün',
            4:'Dördüncü Gün', 5:'Beşinci Gün', 6:'Altıncı Gün',
            7:'Yedinci Gün', 8:'Sekizinci Gün', 9:'Dokuzuncu Gün', 10:'Onuncu Gün'
        };

        function getDayLabel(day) {
            return dayLabels[day] || (day + '. Gün');
        }

        /* ── Önizleme güncelle ── */
        function refreshPreview() {
            var day   = parseInt(document.getElementById('dayInput').value) || 0;
            var title = document.getElementById('planTitle').value.trim();
            var desc  = document.getElementById('planDesc').value;
            var color = getDayColor(day);

            /* Aksan şeridi */
            document.getElementById('prevAccent').style.background = color;

            /* Gün rozeti */
            document.getElementById('prevDayBadge').style.background = color;
            document.getElementById('prevDayNum').textContent = day > 0 ? day : '—';

            /* Renk şeridi + etiket */
            document.getElementById('dayColorStrip').style.background = color;
            var lbl = document.getElementById('dayLabel');
            lbl.textContent = day > 0 ? getDayLabel(day) : '— gün seçin —';
            lbl.style.color = day > 0 ? color : 'var(--t3)';

            /* Başlık */
            var prevTitle = document.getElementById('prevTitle');
            prevTitle.innerHTML = title
                ? '<strong>' + escHtml(title) + '</strong>'
                : '<span style="color:var(--t3);font-weight:400;font-size:12px;">Başlık girilmedi…</span>';

            /* Açıklama */
            var prevDesc = document.getElementById('prevDesc');
            if (desc.trim()) {
                prevDesc.textContent = desc;
                prevDesc.style.fontStyle = 'normal';
                prevDesc.style.color = 'var(--t2)';
            } else {
                prevDesc.innerHTML = '<span style="color:var(--t3);font-style:italic;font-size:12px;">Açıklama girilmedi…</span>';
            }

            /* Satır + karakter sayısı */
            var lineCount = desc.trim() ? desc.split('\n').filter(function(l){ return l.trim().length > 0; }).length : 0;
            document.getElementById('prevLineCount').textContent = lineCount + ' aktivite satırı';
            document.getElementById('prevFooterIcon').style.color = color;

            /* Sayaçlar */
            document.getElementById('descCount').textContent = desc.length;
            document.getElementById('metaLineCount').textContent = lineCount + ' satır';
            document.getElementById('metaCharCount').textContent = desc.length;

            /* Meta gün badge */
            var metaBadge = document.getElementById('metaDayBadge');
            metaBadge.style.background = color;
            metaBadge.textContent = day > 0 ? day + '. Gün' : '—';

            /* Sayfa alt başlık */
            var sub = document.getElementById('pageSubtitle');
            if (sub) {
                sub.style.color = color;
                sub.textContent = day > 0
                    ? (day + '. Gün' + (title ? ': ' + title : ''))
                    : (title || '');
            }

            /* Dirty check */
            var dirty =
                document.getElementById('dayInput').value   !== orig.day   ||
                document.getElementById('planTitle').value  !== orig.title ||
                document.getElementById('planDesc').value   !== orig.desc;

            document.getElementById('changeAlert').classList.toggle('visible', dirty);
        }

        function escHtml(s) {
            return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        /* ── + / - butonları ── */
        function changeDay(delta) {
            var val = parseInt(document.getElementById('dayInput').value) || 0;
            val = Math.max(1, Math.min(365, val + delta));
            document.getElementById('dayInput').value = val;
            refreshPreview();
        }

        function onDayInput() {
            var val = parseInt(document.getElementById('dayInput').value);
            if (val < 1)   document.getElementById('dayInput').value = 1;
            if (val > 365) document.getElementById('dayInput').value = 365;
            refreshPreview();
        }

        /* ── Dinleyiciler ── */
        document.getElementById('planTitle').addEventListener('input', refreshPreview);
        document.getElementById('planDesc').addEventListener('input', refreshPreview);
        document.getElementById('dayInput').addEventListener('input', onDayInput);

        /* ── Sayfadan ayrılma koruması ── */
        window.addEventListener('beforeunload', function(e) {
            if (document.getElementById('changeAlert').classList.contains('visible')) {
                e.preventDefault(); e.returnValue = '';
            }
        });

        document.getElementById('editPlanForm').addEventListener('submit', function() {
            document.getElementById('changeAlert').classList.remove('visible');
        });

        /* ── Silme onayı ── */
        var planTitleForDelete = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model?.Title ?? ""));

        function confirmDelete() {
            if (confirm('"' + planTitleForDelete + '" planını kalıcı olarak silmek istediğinize emin misiniz?')) {
                document.getElementById('deleteForm').submit();
            }
        }

        refreshPreview();
    </script>
}
