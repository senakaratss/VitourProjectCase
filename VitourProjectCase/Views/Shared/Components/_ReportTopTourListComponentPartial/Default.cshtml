@model List<ResultTopTourDto>
<div class="v-card">
    <div class="v-card-header">
        <div class="v-card-icon" style="background:rgba(217,119,6,.1);color:#d97706;"><i class="fa-solid fa-trophy"></i></div>
        <div>
            <div class="v-card-title">En Popüler Turlar</div>
            <div class="v-card-sub">Rezervasyon sayısına göre</div>
        </div>
    </div>
    <div class="v-card-body">
        @{
            
            // Yüzde hesaplamak için max rezervasyon sayısını bul
            var maxCount = Model.Max(t => t.TotalReservations);
            var rankLabels = new[] { "1", "2", "3", "4", "5" };
            int i = 0;

            // Renkleri belirleyelim (1-3 için ödül, 4-5 default)
            string GetColor(int index) => index switch
            {
                0 => "#d97706", // gold
                1 => "#0284c7", // silver
                2 => "#7c3aed", // bronze
                3 => "#16a34a",
                4 => "#e11d48",
            };
        }


        @foreach (var t in Model)
        {
            var pct = maxCount == 0 ? 0 : (int)Math.Round((double)t.TotalReservations / maxCount * 100);
            var color = GetColor(i);
            var rank = i switch { 0 => "gold", 1 => "silver", 2 => "bronze", _ => "" };

            <div class="list-row">
                <div class="list-rank @rank">@rankLabels[i]</div>
                <div class="list-info">
                    <div class="list-name">@t.Title</div>
                    <div class="spark-bar"><div class="spark-fill" style="width:@pct%;background:@color;"></div></div>
                </div>
                <div>
                    <div class="list-val">@t.TotalReservations</div>
                    <div class="list-val-sub">rezervasyon</div>
                </div>
            </div>
            i++;
        }
    </div>
</div>
