@model List<MonthlyRevenueDto>

<div class="v-card">
    <div class="v-card-header">
        <div class="v-card-icon" style="background:rgba(2,132,199,.1);color:#0284c7;">
            <i class="fa-solid fa-chart-column"></i>
        </div>
        <div>
            <div class="v-card-title">Aylık Gelir</div>
            <div class="v-card-sub">Son 8 ay · TL</div>
        </div>
    </div>
    <div class="v-card-body" style="padding-bottom:12px;">
        <div class="chart-area" id="revenueChart"></div>
    </div>
    <div style="display:flex;align-items:center;gap:8px;padding:12px 20px;background:var(--bg-card);border-top:1px solid var(--border);">
        <span style="font-size:12.5px;color:var(--t3);margin-right:4px;">Dışa aktar:</span>
        <button style="display:inline-flex;align-items:center;gap:6px;height:32px;padding:0 12px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:#fff;color:var(--t2);font-family:inherit;font-size:12px;font-weight:600;cursor:pointer;transition:all .16s;"
                onmouseover="this.style.background='var(--bg-hover)';this.style.borderColor='var(--accent)'"
                onmouseout="this.style.background='#fff';this.style.borderColor='var(--border)'">
            <i class="fa-solid fa-file-csv"></i> CSV
        </button>
        <button style="display:inline-flex;align-items:center;gap:6px;height:32px;padding:0 12px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:#fff;color:var(--t2);font-family:inherit;font-size:12px;font-weight:600;cursor:pointer;transition:all .16s;"
                onmouseover="this.style.background='var(--bg-hover)';this.style.borderColor='var(--accent)'"
                onmouseout="this.style.background='#fff';this.style.borderColor='var(--border)'">
            <i class="fa-regular fa-file-excel"></i> Excel
        </button>
    </div>
</div>

<script>
    (function() {
        var data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                        Model.Select(x => new { month = x.Month, val = x.Revenue })
                ));

        var max = Math.max(...data.map(d => d.val));
        var chart = document.getElementById('revenueChart');
        if (!chart) return;

        chart.innerHTML = "";

        data.forEach(function(d) {
            var h = max === 0 ? 0 : Math.round((d.val / max) * 100);

            var wrap = document.createElement('div');
            wrap.className = 'bar-wrap';

            wrap.innerHTML =
                '<div class="bar" style="height:' + h + '%;background:linear-gradient(180deg,#0284c7,#38bdf8);">' +
                    '<div class="bar-tooltip">₺' + (d.val/1000).toFixed(0) + 'K</div>' +
                '</div>' +
                '<div class="bar-lbl">' + d.month + '</div>';

            chart.appendChild(wrap);
        });

    })();
</script>