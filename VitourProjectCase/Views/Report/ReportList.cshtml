@{
    ViewData["Title"] = "Raporlar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActiveMenu"] = "raporlar";
    ViewData["Breadcrumb"] = "Raporlar";
}

<style>
    /* ── KPI ──────────────────────────────────────────────────── */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .kpi-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 20px;
        position: relative;
        overflow: hidden;
    }

        .kpi-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
        }

        .kpi-card.blue::before {
            background: linear-gradient(90deg,#0284c7,#38bdf8);
        }

        .kpi-card.green::before {
            background: linear-gradient(90deg,#16a34a,#4ade80);
        }

        .kpi-card.amber::before {
            background: linear-gradient(90deg,#d97706,#fbbf24);
        }

        .kpi-card.purple::before {
            background: linear-gradient(90deg,#7c3aed,#c084fc);
        }

    .kpi-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 12px;
    }

    .kpi-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
    }

    .kpi-trend {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 11.5px;
        font-weight: 700;
        padding: 3px 8px;
        border-radius: 12px;
    }

        .kpi-trend.up {
            background: rgba(22,163,74,.1);
            color: #16a34a;
        }

        .kpi-trend.flat {
            background: rgba(100,116,139,.1);
            color: #64748b;
        }

    .kpi-val {
        font-size: 26px;
        font-weight: 800;
        color: var(--t1);
        line-height: 1.1;
    }

    .kpi-lbl {
        font-size: 12.5px;
        color: var(--t3);
        margin-top: 4px;
    }

    .kpi-sub {
        font-size: 11.5px;
        color: var(--t3);
        margin-top: 8px;
        border-top: 1px solid #f1f5f9;
        padding-top: 8px;
    }

        .kpi-sub b {
            color: var(--t2);
        }

    /* ── Kart ─────────────────────────────────────────────────── */
    .v-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .v-card-header {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .v-card-icon {
        width: 34px;
        height: 34px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
    }

    .v-card-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--t1);
    }

    .v-card-sub {
        font-size: 12px;
        color: var(--t3);
        margin-top: 1px;
    }

    .v-card-body {
        padding: 20px;
    }

    /* ── İki sütun ────────────────────────────────────────────── */
    .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    /* ── Bar chart ────────────────────────────────────────────── */
    .chart-area {
        height: 220px;
        display: flex;
        align-items: flex-end;
        gap: 6px;
        padding: 0 4px 28px;
    }

    .bar-wrap {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        height: 100%;
        justify-content: flex-end;
    }

    .bar {
        width: 100%;
        border-radius: 5px 5px 0 0;
        position: relative;
        cursor: pointer;
        transition: opacity .2s;
    }

        .bar:hover {
            opacity: .82;
        }

    .bar-tooltip {
        display: none;
        position: absolute;
        bottom: calc(100% + 6px);
        left: 50%;
        transform: translateX(-50%);
        background: var(--t1);
        color: #fff;
        font-size: 11px;
        font-weight: 600;
        padding: 4px 8px;
        border-radius: 6px;
        white-space: nowrap;
        pointer-events: none;
        z-index: 10;
    }

        .bar-tooltip::after {
            content: '';
            position: absolute;
            top: 100%;
            left: 50%;
            transform: translateX(-50%);
            border: 4px solid transparent;
            border-top-color: var(--t1);
        }

    .bar:hover .bar-tooltip {
        display: block;
    }

    .bar-lbl {
        font-size: 10px;
        color: var(--t3);
        font-weight: 600;
        text-align: center;
    }

    /* ── Top turlar ───────────────────────────────────────────── */
    .list-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 11px 0;
        border-bottom: 1px solid #f1f5f9;
    }

        .list-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

    .list-rank {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: var(--bg-card);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        color: var(--t3);
        flex-shrink: 0;
    }

        .list-rank.gold {
            background: #fef3c7;
            border-color: #fcd34d;
            color: #92400e;
        }

        .list-rank.silver {
            background: #f1f5f9;
            border-color: #cbd5e1;
            color: #475569;
        }

        .list-rank.bronze {
            background: #ffedd5;
            border-color: #fdba74;
            color: #9a3412;
        }

    .list-info {
        flex: 1;
        min-width: 0;
    }

    .list-name {
        font-size: 13px;
        font-weight: 600;
        color: var(--t1);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .spark-bar {
        height: 4px;
        background: #f1f5f9;
        border-radius: 99px;
        margin-top: 5px;
    }

    .spark-fill {
        height: 100%;
        border-radius: 99px;
    }

    .list-val {
        font-size: 13.5px;
        font-weight: 700;
        color: var(--t1);
        text-align: right;
        white-space: nowrap;
    }

    .list-val-sub {
        font-size: 11px;
        color: var(--t3);
        text-align: right;
        margin-top: 1px;
    }

    /* ── Hedefler ─────────────────────────────────────────────── */
    .goal-row {
        margin-bottom: 16px;
    }

        .goal-row:last-child {
            margin-bottom: 0;
        }

    .goal-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 6px;
        font-size: 13px;
    }

    .goal-name {
        font-weight: 600;
        color: var(--t1);
    }

    .goal-pct {
        font-weight: 700;
        font-size: 13.5px;
    }

    .goal-track {
        height: 8px;
        background: #f1f5f9;
        border-radius: 99px;
        overflow: hidden;
    }

    .goal-prog {
        height: 100%;
        border-radius: 99px;
    }

    .goal-sub {
        font-size: 11.5px;
        color: var(--t3);
        margin-top: 4px;
    }

    /* ── Filtre bar ───────────────────────────────────────────── */

    @@media(max-width:960px) {
        .kpi-grid {
            grid-template-columns: repeat(2,1fr);
        }

        .two-col {
            grid-template-columns: 1fr;
        }
    }

    @@media(max-width:520px) {
        .kpi-val {
            font-size: 20px;
        }
    }
</style>

<!-- ── Başlık ─────────────────────────────────────────────────── -->
<div style="margin-bottom:24px;">
    <h1 style="font-size:20px;font-weight:700;color:var(--t1);">Raporlar</h1>
    <p style="font-size:13px;color:var(--t3);margin-top:3px;">
        <i class="fa-regular fa-calendar" style="margin-right:5px;"></i>
        @DateTime.Now.ToString("MMMM yyyy", new System.Globalization.CultureInfo("tr-TR")) — Aylık Rapor
    </p>
</div>

<!-- ── KPI ────────────────────────────────────────────────────── -->
@await Component.InvokeAsync("_ReportKpiCardsComponentPartial")
<!-- ── Grafik + Top Turlar ─────────────────────────────────────── -->
<div class="two-col">

    <!-- Gelir grafiği -->
    @await Component.InvokeAsync("_ReportRevenueChartComponentPartial")

    <!-- Top turlar -->
    @await Component.InvokeAsync("_ReportTopTourListComponentPartial")

</div>

<!-- ── Hedefler (tek satır) ────────────────────────────────────── -->
@await Component.InvokeAsync("_ReportGoalsComponentPartial")

